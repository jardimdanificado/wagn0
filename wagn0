#!/usr/bin/env bash
# wagno - CLI tool for WagnO game development
set -euo pipefail

WAGNO_DIR="$(cd "$(dirname "$0")" && pwd)"
TEMPLATES="$WAGNO_DIR/templates"
INCLUDE_DIR="-I${WAGNO_DIR}/include"
HOST_BINARY="${WAGNO_DIR}/wagnostic"
RUNNER="${WAGN0_RUNNER:-}"

RED='\033[31m'
GREEN='\033[32m'
CYAN='\033[36m'
RESET='\033[0m'

info()  { printf "  ${CYAN}>${RESET} %s\n" "$*"; }
ok()    { printf "  ${GREEN}\u2713${RESET} %s\n" "$*"; }
err()   { printf "  ${RED}!${RESET} %s\n" "$*" >&2; }

usage() {
    cat <<'EOF'
wagn0 - CLI tool for WagnO game development

Usage:
    wagn0 new <name>         Create a new project
    wagn0 init               Initialize current directory
    wagn0 build [--release]  Build the WASM ROM
    wagn0 run [<file>]       Run a WASM ROM
    wagn0 dev                Watch, rebuild, and run on changes
EOF
}

# ── JSON helpers ─────────────────────────────────────────────────────────────

load_config() {
    NAME=""; WIDTH=320; HEIGHT=240; SCALE=4; BPP=16; MEMORY=8388608; SRC=""
    [ -f wagn0.json ] || return 0
    local tmp
    tmp=$(grep -o '"name"[[:space:]]*:[[:space:]]*"[^"]*"' wagn0.json 2>/dev/null) && NAME="${tmp#*:}" && NAME="${NAME# }" && NAME="${NAME#\"}" && NAME="${NAME%\"}"
    tmp=$(grep -o '"width"[[:space:]]*:[[:space:]]*[0-9]*' wagn0.json 2>/dev/null) && WIDTH="${tmp#*:}" && WIDTH="${WIDTH# }"
    tmp=$(grep -o '"height"[[:space:]]*:[[:space:]]*[0-9]*' wagn0.json 2>/dev/null) && HEIGHT="${tmp#*:}" && HEIGHT="${HEIGHT# }"
    tmp=$(grep -o '"scale"[[:space:]]*:[[:space:]]*[0-9]*' wagn0.json 2>/dev/null) && SCALE="${tmp#*:}" && SCALE="${SCALE# }"
    tmp=$(grep -o '"bpp"[[:space:]]*:[[:space:]]*[0-9]*' wagn0.json 2>/dev/null) && BPP="${tmp#*:}" && BPP="${BPP# }"
    tmp=$(grep -o '"memory"[[:space:]]*:[[:space:]]*[0-9]*' wagn0.json 2>/dev/null) && MEMORY="${tmp#*:}" && MEMORY="${MEMORY# }"
    SRC=$(grep -oP '"[^"]*\.c"' wagn0.json 2>/dev/null | sed 's/"//g' | tr '\n' ' ' || true)
    [ -n "$NAME" ] || NAME="$(basename "$(pwd)")"
}

# ── Host finder ──────────────────────────────────────────────────────────────

find_host() {
    local names
    case "$RUNNER" in
        sm|spidermonkey) names=("wagnostic-sm" "$HOST_BINARY") ;;
        native|wasm3|"") names=("$HOST_BINARY" "wagnostic" "wagnostic-sm") ;;
        *)
            err "Unknown runner: $RUNNER (use 'native' or 'sm')"
            return 1
            ;;
    esac
    for name in "${names[@]}"; do
        command -v "$name" &>/dev/null && { echo "$name"; return 0; }
        [ -x "$name" ] && { echo "$name"; return 0; }
    done
    return 1
}

build_host() {
    info "To build the host runner, clone the wagnostic repo and run:"
    info "  make -C examples"
    err "Host binary not found. Install or build wagnostic first."
    return 1
    local out="${1:-./wagnostic}"
    info "Building host binary..."
    if ! command -v gcc &>/dev/null; then
        err "gcc not found. Install build-essential."
        return 1
    fi
    local wasm3_src
    wasm3_src=$(find "$wasm3_dir" -maxdepth 1 -name '*.c' 2>/dev/null | tr '\n' ' ' || true)
    [ -z "$wasm3_src" ] && { err "wasm3 source not found at $wasm3_dir"; return 1; }
    gcc -I"$wasm3_dir" -O2 "$host_src" $wasm3_src -o "$out" -lSDL2 -lm && \
        ok "Host built: $out" || { err "Host build failed"; return 1; }
}

# ── Build WASM ───────────────────────────────────────────────────────────────

build_wasm() {
    local release="${1:-}"
    local opt="-O2"

    load_config
    [ -d "${WAGNO_DIR}/include" ] || { err "Include directory not found"; return 1; }

    local target="${NAME}.wasm"
    local src_files
    if [ -n "$SRC" ]; then
        src_files="$SRC"
    else
        src_files=$(echo *.c)
    fi
    src_files=$(echo "$src_files" | tr ' ' '\n' | grep -v '^\*' | tr '\n' ' ' || true)
    [ -z "$src_files" ] && { err "No source files found"; return 1; }

    local clang
    clang=$(command -v clang) || clang=clang
    [ "$release" = "release" ] && opt="-O3"

    info "Compiling ${NAME} -> ${target}"
    info "Compiling ${NAME} -> ${target}"
    
    # Delete old assets.h if exists
    [ -f assets.h ] && rm assets.h

    # Detect which decoders are needed and add their source + include paths
    local decoder_c_files=""
    local decoder_inc="-I${WAGNO_DIR}/lib/include"
    local shim_c="${WAGNO_DIR}/lib/shim/libc_shim.c"
    if find assets -name '*.png' -o -name '*.jpg' -o -name '*.jpeg' -o -name '*.bmp' 2>/dev/null | grep -q .; then
        decoder_c_files="$decoder_c_files ${WAGNO_DIR}/lib/decoders/lodepng.c"
        decoder_inc="$decoder_inc -I${WAGNO_DIR}/lib/decoders \
            -DLODEPNG_NO_COMPILE_DISK -DLODEPNG_NO_COMPILE_ENCODER \
            -DLODEPNG_NO_COMPILE_ANCILLARY_CHUNKS -DLODEPNG_NO_COMPILE_ERROR_TEXT"
    else
        # No PNG assets: disable png_decode to avoid lodepng_decode32 import
        decoder_inc="$decoder_inc -DWAGN0_NO_PNG_DECODE"
    fi
    if find assets -name '*.gif' 2>/dev/null | grep -q .; then
        decoder_c_files="$decoder_c_files ${WAGNO_DIR}/lib/decoders/gifdec.c \
                         ${WAGNO_DIR}/lib/decoders/posix_shim.c"
        decoder_inc="$decoder_inc -I${WAGNO_DIR}/lib/decoders"
    else
        decoder_inc="$decoder_inc -DWAGN0_NO_GIF_DECODE \
            -I${WAGNO_DIR}/lib/decoders"
    fi
    if find assets -name '*.wav' -o -name '*.mp3' -o -name '*.ogg' 2>/dev/null | grep -q .; then
        decoder_inc="$decoder_inc -I${WAGNO_DIR}/lib/decoders \
                     -DSTB_VORBIS_NO_STDIO"
        decoder_c_files="$decoder_c_files ${WAGNO_DIR}/lib/decoders/stb_vorbis.c"
    fi
    if find assets -name '*.wav' -o -name '*.mp3' -o -name '*.ogg' 2>/dev/null | grep -q .; then
        :  # has audio — don't disable decoders
    else
        decoder_inc="$decoder_inc -DWAGN0_NO_AUDIO_DECODE"
    fi
    # Always link the shim. It provides strlen (so clang's
    # text_width optimization doesn't emit env.strlen), memcpy/
    # memset/memmove/abort (libc), and the software libm (sin/cos/exp
    # /log/pow/ldexp/floor/ceil/fabs) for audio decoders. The size
    # cost is small (~3KB) and keeps the WASM zero-import.
    decoder_c_files="$decoder_c_files $shim_c"

    local config_flags="-DWAGN0_TITLE=\"$NAME\" -DWAGN0_CFG_W=$WIDTH -DWAGN0_CFG_H=$HEIGHT -DWAGN0_CFG_BPP=$BPP -DWAGN0_CFG_SCALE=$SCALE"

    if ! "$clang" --target=wasm32 -nostdlib -fno-delete-null-pointer-checks \
        $opt -w $INCLUDE_DIR -I. $decoder_inc $config_flags \
        -Wl,--no-entry -Wl,--export-all -Wl,--allow-undefined \
        -Wl,--initial-memory="${MEMORY}" \
        -o "$target" $src_files $decoder_c_files 2>&1; then
        err "Build failed"
        return 1
    fi

    if [ -f "$target" ]; then
        local size
        size=$(stat -c%s "$target" 2>/dev/null || stat -f%z "$target" 2>/dev/null)
        local kb=$((size / 1024))
        local dec=$(((size % 1024) * 10 / 1024))
        ok "${target} (${kb}.${dec} KB)"
        
        # Package into .tar if assets exist
        if [ -d "assets" ] && [ -n "$(ls -A assets 2>/dev/null)" ]; then
            local wag_target="${NAME}.tar"
            local tmpdir
            tmpdir=$(mktemp -d)
            cp "$target" "$tmpdir/main.wasm"
            cp -r assets/* "$tmpdir/"
            (cd "$tmpdir" && tar -cf "$wag_target" --format=ustar *)
            mv "$tmpdir/$wag_target" "./$wag_target"
            rm -rf "$tmpdir"
            
            local wsize
            wsize=$(stat -c%s "$wag_target" 2>/dev/null || stat -f%z "$wag_target" 2>/dev/null)
            local wkb=$((wsize / 1024))
            local wdec=$(((wsize % 1024) * 10 / 1024))
            ok "${wag_target} (${wkb}.${wdec} KB) [TAR]"
        fi
        
        return 0
    else
        err "Build failed"
        return 1
    fi
}

# ── Run WASM ─────────────────────────────────────────────────────────────────

run_wasm() {
    local wasm="$1"
    local host
    host=$(find_host) || true
    if [ -z "$host" ]; then
        info "Host not found. Building..."
        host="./wagnostic"
        build_host "$host" || return 1
    fi
    info "Running: $(basename "$host") $(basename "$wasm")"
    "$host" "$wasm"
}

# ── Commands ─────────────────────────────────────────────────────────────────

cmd_new() {
    local name="$1"
    [ -d "$name" ] && { err "'$name' already exists"; return 1; }
    mkdir -p "$name/assets"
    cp "$TEMPLATES/main.c" "$TEMPLATES/Makefile" "$name/"
    sed "s|\"name\": \"\"|\"name\": \"$name\"|" "$TEMPLATES/wagn0.json" > "$name/wagn0.json"
    ok "Project '$name' created in $(pwd)/$name/"
    info "  cd $name && wagn0 dev"
}

cmd_init() {
    local force="${1:-}"
    for f in main.c Makefile; do
        [ -f "$f" ] && [ -z "$force" ] && { err "$f exists, use --force"; continue; }
        cp "$TEMPLATES/$f" "$f" && ok "$f created"
    done
    if [ ! -f wagn0.json ] || [ -n "$force" ]; then
        local dname
        dname=$(basename "$(pwd)")
        sed "s|\"name\": \"\"|\"name\": \"$dname\"|" "$TEMPLATES/wagn0.json" > wagn0.json
        ok "wagn0.json created"
    fi
    mkdir -p assets
}

cmd_build() {
    build_wasm "${1:-}"
}

cmd_run() {
    # Parse --runner flag
    while [ $# -gt 0 ]; do
        case "$1" in
            --runner) RUNNER="$2"; shift 2 ;;
            --runner=*) RUNNER="${1#*=}"; shift ;;
            *) break ;;
        esac
    done
    local file="${1:-}"
    if [ -z "$file" ]; then
        load_config
        if [ -f "${NAME}.tar" ]; then
            file="${NAME}.tar"
        elif [ -f "${NAME}.wasm" ]; then
            file="${NAME}.wasm"
        elif [ -f "game.tar" ]; then
            file="game.tar"
        else
            file="game.wasm"
        fi
    fi
    [ ! -f "$file" ] && { err "ROM file not found: $file"; info "Build first: wagn0 build"; return 1; }
    run_wasm "$file"
}

cmd_dev() {
    # Parse --runner flag
    while [ $# -gt 0 ]; do
        case "$1" in
            --runner) RUNNER="$2"; shift 2 ;;
            --runner=*) RUNNER="${1#*=}"; shift ;;
            *) break ;;
        esac
    done
    load_config
    local target="${NAME}.wasm"
    local host_pid=0

    rebuild_and_run() {
        [ "$host_pid" -ne 0 ] && kill "$host_pid" 2>/dev/null || true
        if build_wasm; then
            local run_tgt="$target"
            [ -f "${NAME}.tar" ] && run_tgt="${NAME}.tar"
            run_wasm "$run_tgt" &
            host_pid=$!
        fi
    }

    rebuild_and_run
    while true; do
        if command -v inotifywait &>/dev/null; then
            inotifywait -q -r -e modify -e create -e delete \
                --exclude '\.(wasm|o)$' . 2>/dev/null
        else
            sleep 0.5
            local found=0
            for f in $(find . \( -name '*.c' -o -name '*.h' -o -name '*.json' \) 2>/dev/null); do
                local m
                m=$(stat -c%Y "$f" 2>/dev/null || stat -f%m "$f" 2>/dev/null)
                local var="_mtime_${f//[.\/]/_}"
                local old
                eval "old=\${$var:-0}"
                [ "$m" != "$old" ] && [ "$old" -ne 0 ] && found=1
                eval "$var=$m"
            done
            [ "$found" -eq 1 ] && rebuild_and_run
            continue
        fi
        rebuild_and_run
    done
}

# ── Asset pipeline (removed, using .tar tar packaging instead) ────────────

# ── Main ─────────────────────────────────────────────────────────────────────

main() {
    [ $# -eq 0 ] && { usage; exit 1; }

    case "$1" in
        new)
            [ $# -lt 2 ] && { err "Usage: wagn0 new <name>"; exit 1; }
            cmd_new "$2"
            ;;
        init)
            cmd_init "${2:-}"
            ;;
        build)
            cmd_build "${2:-}"
            ;;
        run)
            cmd_run "${2:-}"
            ;;
        dev)
            cmd_dev
            ;;
        help|--help|-h)
            usage
            ;;
        *)
            err "Unknown command: $1"
            usage
            exit 1
            ;;
    esac
}

main "$@"
